# Ignore configuration files that may contain sensitive information.
/docroot/sites/*/*settings*.php

# don't add Drupal core in the event that composer sticks it in as a dependency
/docroot/core/


# Ignore paths that contain generated content.
/docroot/files
/docroot/sites/*/files
/docroot/sites/*/files-private


# Ignore contrib modules, themes, and libraries
/docroot/modules/contrib
/docroot/profiles/contrib
/docroot/themes/contrib
/docroot/themes/**/bower_components
/docroot/themes/**/.sass-cache

# Ignore local configuration files that may contain sensitive information.
settings.local.php
services.local.yml


#Ignore the bin directory
bin/

# Ignore the node modules folder
node_modules/
/**/node_modules

# Ignore Sass map files since they only work locally anyway
*.css.map

# Composer dependencies
/docroot/vendor
/vendor

# PhpUnit code coverage generated files
/docroot/tests/coverage

# Ignore any .git folders that might come in via composer
/**/.git

# Behat local config
/docroot/behat.yml

# PhpUnit local config
/docroot/phpunit.xml

# log files
/**/*.log
/**/.sass-cache
composer.lock
/**/services.yml

docroot/libraries/chosen-js
docroot/libraries/slick-carousel
docroot/libraries/jquery-colorbox

# Ignore Packages
*.7z
*.dmg
*.gz
*.bz2
*.iso
*.jar
*.rar
*.tar
*.zip
*.tgz

# Logs and databases
*.log
*.sql

# OS generated files
.DS_Store*
ehthumbs.db
Icon
Thumbs.db
._*

# Ignore files generated by PhpStorm
.idea

# Ignore local Docksal config file
docksal-local.env
